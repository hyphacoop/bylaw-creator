{
  "functions": {
    "api/anthropic/messages.js": {
      "maxDuration": 60
    },
    "api/ollama/generate.js": {
      "maxDuration": 60
    },
    "api/jobs/submit.js": {
      "maxDuration": 10
    },
    "api/jobs/process.js": {
      "maxDuration": 300
    },
    "api/jobs/status.js": {
      "maxDuration": 10
    }
  },
  "build": {
    "env": {
      "REACT_APP_API_URL": ""
    }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, X-Internal-Request"
        }
      ]
    }
  ]
} 